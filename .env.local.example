# ─────────────────────────────────────────────────────────────
#  Fixible — Environment Variables Template
#  Copy this file to .env.local and fill in the values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Cal.com Booking ──────────────────────────────────────────
# Your Cal.com username (e.g. "fixible")
# Used in data/business.ts → booking.calUsername
NEXT_PUBLIC_CAL_USERNAME=fixible

# ── Analytics (optional) ─────────────────────────────────────
# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Email (future — when domain email is set up) ─────────────
# Replace fixible.ca@gmail.com with hello@fixible.ca once ready
# Update data/business.ts → email field at that point
